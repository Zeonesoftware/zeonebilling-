rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'zeonesoftware@gmail.com' ||
        getUserData().role == 'admin'
      );
    }

    function isBilling() {
      return isSignedIn() && (
        request.auth.token.email == 'zeonesoftware@gmail.com' ||
        getUserData().role in ['admin', 'billing']
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['email', 'name', 'role', 'createdAt']) &&
               data.keys().size() >= 4 && // Role is strictly checked. phone/permissions are optional.
               data.email is string && data.email.size() <= 256 &&
               data.name is string && data.name.size() <= 128 &&
               data.role in ['admin', 'billing', 'removed'] &&
               data.createdAt is string;
      }

      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    isValidUser(incoming()) &&
                    (incoming().role == (request.auth.token.email == 'zeonesoftware@gmail.com' ? 'admin' : 'billing'));
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'phoneNumber']))
      ) && isValidUser(incoming());
      
      allow delete: if isAdmin();
    }

    // --- Business Logic Collections ---
    // All these share a similar access pattern: Admin/Billing can manage
    
    match /clients/{clientId} {
      function isValidClient(data) {
        return data.name is string && data.name.size() <= 128 &&
               data.email is string && data.email.size() <= 128;
      }
      allow list, get: if isBilling();
      allow create: if isBilling() && isValidId(clientId) && isValidClient(incoming());
      allow update: if isBilling() && isValidClient(incoming());
      allow delete: if isAdmin();
    }

    match /items/{itemId} {
      function isValidItem(data) {
        return data.name is string && data.name.size() <= 128 &&
               data.price is number && data.price >= 0 &&
               data.gstRate is number && data.gstRate >= 0;
      }
      allow list, get: if isBilling();
      allow create: if isBilling() && isValidId(itemId) && isValidItem(incoming());
      allow update: if isBilling() && isValidItem(incoming());
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      function isValidInvoice(data) {
        return data.invoiceNumber is string && data.invoiceNumber.size() <= 64 &&
               data.clientId is string &&
               data.totalAmount is number;
      }
      allow list: if isBilling() && (isAdmin() || resource.data.createdBy == request.auth.uid);
      allow get: if isBilling();
      allow create: if isBilling() && isValidId(invoiceId) && isValidInvoice(incoming()) &&
                    incoming().createdAt == request.time;
      allow update: if isBilling() && (
        isAdmin() || 
        (existing().status != 'Paid' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      ) && isValidInvoice(incoming());
      allow delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read, write: if isBilling();
    }

    match /purchases/{purchaseId} {
      allow read, write: if isBilling();
    }

    match /settings/{settingId} {
      allow read: if isBilling();
      allow write: if isAdmin();
    }
  }
}
