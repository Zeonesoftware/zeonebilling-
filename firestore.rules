rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData(request.auth.uid).role == 'admin';
    }

    function isBilling() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (getUserData(request.auth.uid).role == 'admin' || getUserData(request.auth.uid).role == 'billing');
    }

    function isAnyUser() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) && 
             data.email is string &&
             data.role in ['admin', 'billing', 'removed'] &&
             (!('permissions' in data) || data.permissions is list) &&
             data.keys().size() <= 20;
    }

    function isValidInvoice(data) {
       return data.keys().hasAll(['invoiceNumber', 'clientId', 'totalAmount', 'status']) &&
              data.invoiceNumber is string &&
              data.clientId is string &&
              data.totalAmount is number &&
              data.status in ['Draft', 'Paid', 'Pending', 'Cancelled', 'Delivered'] &&
              data.keys().size() <= 80;
    }

    function isValidClient(data) {
      return data.keys().hasAll(['name', 'email']) &&
             data.name is string &&
             data.email is string &&
             data.keys().size() <= 40;
    }

    function isValidItem(data) {
      return data.keys().hasAll(['name', 'price', 'gstRate']) &&
             data.name is string &&
             data.price is number &&
             data.gstRate is number &&
             data.keys().size() <= 30;
    }

    // --- Rules ---
    match /test/connection {
      allow read: if isSignedIn();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin() && userId != request.auth.uid;
    }

    match /invoices/{invoiceId} {
      allow read, list: if isAnyUser();
      allow create: if isBilling() && isValidInvoice(incoming());
      allow update: if isBilling() && (
        incoming().invoiceNumber == existing().invoiceNumber || isAdmin()
      );
      allow delete: if isBilling();
    }

    match /clients/{clientId} {
      allow read, list: if isAnyUser();
      allow create, update: if isBilling() && isValidClient(incoming());
      allow delete: if isBilling();
    }

    match /items/{itemId} {
      allow read, list: if isAnyUser();
      allow create, update: if isBilling() && isValidItem(incoming());
      allow delete: if isBilling();
    }

    match /expenses/{expenseId} {
      allow read, list: if isAnyUser();
      allow create, update, delete: if isBilling();
    }

    match /purchases/{purchaseId} {
      allow read, list: if isAnyUser();
      allow create, update, delete: if isBilling();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isBilling();
    }
  }
}
