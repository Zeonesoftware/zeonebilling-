rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"role": "none"};
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'zeonesoftware@gmail.com' ||
        getUserData().get('role', 'none') == 'admin'
      );
    }

    function isBilling() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'zeonesoftware@gmail.com' ||
        getUserData().get('role', 'none') in ['admin', 'billing']
      );
    }

    match /test/connection {
      allow read: if isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.get('role', 'none') in ['admin', 'billing', 'removed'] &&
               (data.get('createdAt', '') is timestamp || data.get('createdAt', '') is string);
      }

      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    isValidUser(incoming()) &&
                    (incoming().role == (request.auth.token.email.lower() == 'zeonesoftware@gmail.com' ? 'admin' : 'billing'));
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == userId && 
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'phoneNumber', 'role', 'permissions', 'updatedAt']))
      ) && isValidUser(incoming());
      
      allow delete: if isAdmin();
    }

    // --- Business Logic Collections ---
    // All these share a similar access pattern: Admin/Billing can manage
    
    match /clients/{clientId} {
      function isValidClient(data) {
        return data.get('name', '') is string && data.get('name', '').size() <= 128;
      }
      allow list, get: if isBilling();
      allow create: if isBilling() && isValidId(clientId) && isValidClient(incoming());
      allow update: if isBilling() && isValidClient(incoming());
      allow delete: if isBilling();
    }

    match /items/{itemId} {
      function isValidItem(data) {
        return data.get('name', '') is string && data.get('name', '').size() <= 128 &&
               data.get('price', 0) is number && data.get('price', 0) >= 0;
      }
      allow list, get: if isBilling();
      allow create: if isBilling() && isValidId(itemId) && isValidItem(incoming());
      allow update: if isBilling() && isValidItem(incoming());
      allow delete: if isBilling();
    }

    match /invoices/{invoiceId} {
      function isValidInvoice(data) {
        return data.get('invoiceNumber', '') is string && data.get('invoiceNumber', '').size() <= 64 &&
               data.get('clientId', '') is string;
      }
      allow list: if isBilling();
      allow get: if isBilling();
      allow create: if isBilling() && isValidId(invoiceId) && isValidInvoice(incoming());
      allow update: if isBilling() && (
        isAdmin() || 
        (
          (existing().get('status', '') != 'Paid' || incoming().diff(existing()).affectedKeys().hasOnly(['ackNo', 'ackDate', 'irn', 'signedQrCode', 'einvoiceStatus', 'ewayBillNo', 'ewayBillDate', 'ewayBillStatus', 'updatedAt', 'updatedBy'])) && 
          incoming().diff(existing()).affectedKeys().hasOnly([
            'status', 'updatedAt', 'updatedBy', 'paymentStatus', 'notes',
            'ackNo', 'ackDate', 'irn', 'signedQrCode', 'einvoiceStatus',
            'ewayBillNo', 'ewayBillDate', 'ewayBillStatus'
          ])
        )
      ) && isValidInvoice(incoming());
      allow delete: if isBilling();
    }

    match /expenses/{expenseId} {
      allow read, write: if isBilling();
    }

    match /purchases/{purchaseId} {
      allow read, write: if isBilling();
    }

    match /settings/{settingId} {
      allow read: if isBilling();
      allow write: if isBilling();
    }
  }
}
